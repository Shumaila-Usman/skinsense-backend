PORT=5000
MONGO_URI=mongodb://localhost:27017/skinsense
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
ADMIN_SECRET=your_admin_secret_here

# ─── OpenAI (required for RAG + cure suggestions) ─────────────
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk_your_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ─── Qdrant Vector Database ───────────────────────────────────
# Run: docker run -p 6333:6333 -p 6334:6334 qdrant/qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=skinsense_products

# ─── Provider settings ────────────────────────────────────────
EMBEDDING_PROVIDER=openai
LLM_PROVIDER=openai

# ─── Skin Disease Detection ───────────────────────────────────
SKIN_MODEL_PROVIDER=roboflow
USE_DUMMY_SCAN=false

# Roboflow config — get key at https://roboflow.com
ROBOFLOW_API_KEY=your_roboflow_key_here
ROBOFLOW_WORKSPACE=your_workspace
ROBOFLOW_PROJECT_ID=deep-derma-lmpy4
ROBOFLOW_VERSION=1

# ─── Optional Groq fallback ───────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
